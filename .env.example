# Copy to `.env` and fill in secrets:
#   cp .env.example .env
#
# Loaded automatically by `scripts/run_ipo_optimizer_wrds.py` and several scripts via python-dotenv.

# --- WRDS (Wharton Research Data Services) ---
# Required for non-interactive connections in `src/wrds_data.get_connection()`.
WRDS_USERNAME=
WRDS_PASSWORD=

# --- IPO portfolio optimizer overrides (all optional) ---
# Model: gru | lstm | transformer (also set by `scripts/run_ipo_optimizer_wrds_lstm.py`, etc.)
# IPO_MODEL_TYPE=lstm

# Merge extra JSON after best_config (repo-relative or absolute path)
# IPO_LOCAL_CONFIG=local/ipo_optimizer_config.json

# Learning-rate schedule: constant | cosine | plateau | exponential
# IPO_LR_SCHEDULE=

# Sector baskets: 1 / true / on | 0 / false / off (overrides SECTOR_PORTFOLIOS in code)
# IPO_SECTOR_PORTFOLIOS=1

# Sector labels: compustat | yfinance | ccm | wrds_chain
# IPO_SECTOR_SOURCE=compustat

# Sample range (default 2010-01-01 .. 2024-12-31 in scripts/run_ipo_optimizer_wrds.py)
# IPO_DATA_START=2010-01-01
# IPO_DATA_END=2024-12-31

# Rolling window for train/val loss plot (epochs)
# IPO_LOSS_ROLLING_EPOCHS=3

# Save transformer self-attention maps (1/true/yes when model is transformer)
# IPO_EXPORT_ATTENTION=0
